{
  "name": "securellm-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:adversarial:classic": "powershell -ExecutionPolicy Bypass -File scripts/runAdversarialClassicReport.ps1",
    "test:adversarial:canary": "powershell -ExecutionPolicy Bypass -File scripts/runAdversarialCanaryReport.ps1",
    "seed:keys": "tsx scripts/seedKeys.ts",
    "lint:secrets": ".\\tools\\gitleaks\\gitleaks.exe dir . --config .gitleaks.toml --no-banner"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.5",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
