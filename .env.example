NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://mongo:27017/securellm
REDIS_URL=redis://redis:6379

# Gateway demo keys; run `npm run seed:keys` after setting them.
CLIENT_API_KEY=replace-with-random-client-key
ADMIN_API_KEY=replace-with-random-admin-key
CLIENT_RATE_LIMIT_PER_MINUTE=30
ADMIN_RATE_LIMIT_PER_MINUTE=120

# OpenAI-compatible provider. For Ollama in compose, use http://ollama:11434/v1.
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_MODEL_ALIASES={"gpt-4o":"gpt-oss:20b","claude-3-5-sonnet":"gpt-oss:20b"}

# 32+ byte secret recommended. Used to encrypt reversible PII mappings in audit logs.
PII_ENCRYPTION_KEY=replace-with-32-byte-secret
